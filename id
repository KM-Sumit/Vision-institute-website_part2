        function switchSlide(nextIdx) {
            const slides = document.querySelectorAll('#hero-track > div');
            const dots = document.querySelectorAll('#hero-dots > button');
            if(!slides.length) return;

            slides[currentSlide].classList.replace('opacity-100', 'opacity-0');
            slides[currentSlide].classList.replace('z-10', 'z-0');
            dots[currentSlide].classList.replace('bg-gold', 'bg-white/40');
            dots[currentSlide].classList.remove('w-8');

            currentSlide = (nextIdx + slides.length) % slides.length;

            slides[currentSlide].classList.replace('opacity-0', 'opacity-100');
            slides[currentSlide].classList.replace('z-0', 'z-10');
            dots[currentSlide].classList.replace('bg-white/40', 'bg-gold');
            dots[currentSlide].classList.add('w-8');
        }

        function startSliderLoop() {
            clearInterval(slideInterval);
