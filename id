        // Inquiry Stream Grid Logging Systems
        function renderInquiriesAdminTable() {
            const body = document.getElementById('inquiries-table-body');
            body.innerHTML = '';
            
            if(!inquiriesData.length) {
                body.innerHTML = `<tr><td class="p-8 text-center text-xs text-muted font-mono" colspan="5">Zero inquiry payload intents received by tracking framework nodes.</td></tr>`;
                return;
            }

            inquiriesData.forEach((inq, idx) => {
                const tr = document.createElement('tr');
                const timestamp = new Date(inq.date).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' });
                tr.innerHTML = `
                    <td class="p-4 font-mono text-[11px] text-gray-500">${timestamp}</td>
                    <td class="p-4">
                        <span class="block font-bold text-navy text-xs">${inq.name}</span>
                        <span class="block font-mono text-[10px] text-gray-400">${inq.phone}</span>
                    </td>
                    <td class="p-4">
                        <span class="block text-xs font-bold text-gray-700">Class ${inq.class}</span>
                        <span class="block text-[10px] text-gold font-semibold">${inq.subject}</span>
                    </td>
                    <td class="p-4 text-xs text-gray-600 max-w-xs truncate" title="${inq.message}">${inq.message || '—'}</td>
                    <td class="p-4 text-right"><button onclick="deleteInquiryItem(${idx})" class="text-red-500 hover:text-red-700 p-1"><i data-lucide="trash-2" class="w-4 h-4 inline"></i></button></td>
                `;
                body.appendChild(tr);
            });
            lucide.createIcons();
        }

        window.deleteInquiryItem = function(idx) {
            if(confirm("Purge inquiry log record?")) {
                inquiriesData.splice(idx,1);
                localStorage.setItem('inquiriesData', JSON.stringify(inquiriesData));
                renderInquiriesAdminTable();
                calculateOverviewStats();
            }
        }

        // CSV Tabular Compilations Engine Export Function
        document.getElementById('export-csv-btn').addEventListener('click', () => {
            if(!inquiriesData.length) return alert("Dataset lacks rows to structure effectively.");
            
            let csvRows = [["Timestamp Signature", "Student Name", "Contact Pointer", "Class Field", "Subject Area Target", "Captured Inquiry Text"]];
            inquiriesData.forEach(i => {
                csvRows.push([
                    new Date(i.date).toISOString(),
                    `"${i.name.replace(/"/g, '""')}"`,
                    `"${i.phone}"`,
                    `"${i.class}"`,
                    `"${i.subject.replace(/"/g, '""')}"`,
                    `"${(i.message || '').replace(/"/g, '""')}"`
                ]);
            });

            const csvContent = "data:text/csv;charset=utf-8," + csvRows.map(e => e.join(",")).join("\n");
            const encodedUri = encodeURI(csvContent);
            const downloadAnchor = document.createElement("a");
            downloadAnchor.setAttribute("href", encodedUri);
            downloadAnchor.setAttribute("download", `Inquiry_Log_Export_${Date.now()}.csv`);
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            document.body.removeChild(downloadAnchor);
        });
    </script>
