            // Video Filtering Core Events
            document.getElementById('video-filter-class').addEventListener('change', renderVideos);
            document.getElementById('video-filter-subject').addEventListener('input', renderVideos);
            document.getElementById('video-filter-topic').addEventListener('input', renderVideos);

            // Playback Modals Triggers
            const vidModal = document.getElementById('video-modal');
            const playerContainer = document.getElementById('modal-player-container');
            
            document.getElementById('videos-grid').addEventListener('click', (e) => {
                const trigger = e.target.closest('.play-video-trigger');
