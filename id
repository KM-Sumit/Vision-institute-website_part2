        // ==========================================================
        // ==========================================================
        // DEBUG-ENABLED GOOGLE DRIVE AUTHENTICATION ENGINE
        // ==========================================================
        // ==========================================================
        // SECURE TUNNEL-BASED GOOGLE CLOUD AUTHENTICATION ENGINE
        // ==========================================================
        // ==========================================================
        // UPGRADED REDIRECT-AWARE GOOGLE CLOUD AUTHENTICATION ENGINE
        // ==========================================================
        function setupCloudAuthEngine() {
            // Aapka exact verified Web App URL
            const CLOUD_TUNNEL_URL = 'https://script.google.com/macros/s/AKfycbz0xNwIGPuT9iYIp1UkOYD22d4L5Pyv88PXLdpexHmX3vrCfvmtEOzBpDsrK58kgyqR/exec'; 

            const trigger = document.getElementById('hidden-admin-trigger');
            const modal = document.getElementById('drive-auth-modal');
            const closeBtn = document.getElementById('close-auth-modal');
            const form = document.getElementById('drive-auth-form');
            const input = document.getElementById('drive-auth-input');
            const submitBtn = document.getElementById('drive-auth-submit');
            const errorMsg = document.getElementById('drive-auth-error');
            const btnText = document.getElementById('btn-text');

            if (!trigger || !modal) return;

            trigger.addEventListener('click', () => {
                modal.classList.replace('hidden', 'flex');
                input.focus();
            });

            closeBtn.addEventListener('click', () => {
                modal.classList.replace('hidden', 'flex');
                errorMsg.classList.add('hidden');
                form.reset();
            });

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                errorMsg.classList.add('hidden');
                
                btnText.textContent = "Verifying with Cloud Server...";
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-70');

                const enteredPassword = input.value.trim();

                // Build query parameter URL
                const targetUrl = `${CLOUD_TUNNEL_URL}?password=${encodeURIComponent(enteredPassword)}`;

                try {
                    // Google redirects ko bypass karne ke liye redirect: 'follow' set kiya hai
                    const response = await fetch(targetUrl, {
                        method: 'GET',
                        mode: 'cors',
                        redirect: 'follow', 
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`Cloud Server responded with status: ${response.status}`);
                    }
                    
                    // Response text read karein aur use parse karein
                    const textData = await response.text();
                    let result;
                    
                    try {
                        result = JSON.parse(textData);
                    } catch(jsonErr) {
                        throw new Error(`Invalid server data format. Received: ${textData.substring(0, 50)}...`);
                    }

                    if (result.status === "SUCCESS") {
                        alert("✅ Security Key Match! Access Granted.");
                        // Secure session token store karein
                        localStorage.setItem('admin_session_token', btoa(enteredPassword + '_verified_2026'));
                        window.location.href = 'admin.html';
                    } else if (result.status === "MISMATCH") {
                        alert("❌ Access Denied!\nAapne jo password dala hai woh Google Sheet ke password se match nahi kha raha hai.");
                        errorMsg.classList.remove('hidden');
                        errorMsg.textContent = "Incorrect password matrix signature.";
                    } else {
                        throw new Error(result.message || "Unknown auth response.");
                    }

                } catch (error) {
                    console.error("🚨 Cloud Interface Error:", error);
                    
                    // Detail error reporting screen par taaki problem turant samajh aaye
                    alert(`CONNECTIVITY ALERT!\n\nReason: ${error.message}\n\nSolution Checklist:\n1. Kya aapka internet chalu hai?\n2. Apps Script me "Who has access" abhi bhi "Anyone" par set hai na?\n3. Ek baar Sheet me jaakar check karein ki password sahi cell (A1) me likha hai ya nahi.`);
                    
                    errorMsg.classList.remove('hidden');
                    errorMsg.textContent = `Cloud Node Error: ${error.message}`;
                } finally {
                    btnText.textContent = "Verify Identity";
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-70');
                }
            });
        }
    </script>
</body>
</html>



























