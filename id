    <!-- MAIN ADMINISTRATIVE CONTROL IMPLEMENTATION CORE -->
    <script>
        // ==========================================================
        // ENHANCED GOOGLE DRIVE SECURITY ACCESS PASSPORT GATEWAY CHECK
        // ==========================================================
        (function verifyCloudSession() {
            const sessionToken = localStorage.getItem('admin_session_token');
            const shield = document.getElementById('auth-gate-shield');
            const layout = document.getElementById('dashboard-layout');

            if (sessionToken) {
                // Remove shielding layers if verified security handshake signature passes
                if(shield) shield.remove();
                if(layout) layout.classList.remove('hidden');
                
                // Hydrate dashboard parameters components asynchronously
                setTimeout(() => { initDashboardEngine(); }, 50);
            } else {
                alert("Unauthorized Entry Node. Please authenticate via secure network cloud triggers.");
                window.location.href = 'index.html';
            }
        })();

        // Exit Node Session Invalidation Workflow
        document.getElementById('logout-btn').addEventListener('click', () => {
            localStorage.removeItem('admin_session_token');
            window.location.href = 'index.html';
        });

        // Dashboard Navigation Core Mechanics
        function setupNavigation() {
            const navButtons = document.querySelectorAll('#admin-nav > button');
            navButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    navButtons.forEach(b => b.classList.remove('sidebar-active'));
                    btn.classList.add('sidebar-active');
                    
                    document.querySelectorAll('.admin-panel').forEach(p => p.classList.add('hidden'));
                    document.getElementById(btn.dataset.target).classList.remove('hidden');
                });
            });
            navButtons[0].click();
        }

        // Structural Live Sync Data Parsers
        let siteSettings, sliderData, coursesData, videosData, notesData, galleryData, testimonialsData, inquiriesData;

        function loadDatasetsFromStorage() {
            siteSettings = JSON.parse(localStorage.getItem('siteSettings')) || {};
            sliderData = JSON.parse(localStorage.getItem('sliderData')) || [];
            coursesData = JSON.parse(localStorage.getItem('coursesData')) || [];
            videosData = JSON.parse(localStorage.getItem('videosData')) || [];
            notesData = JSON.parse(localStorage.getItem('notesData')) || [];
            galleryData = JSON.parse(localStorage.getItem('galleryData')) || [];
            testimonialsData = JSON.parse(localStorage.getItem('testimonialsData')) || [];
            inquiriesData = JSON.parse(localStorage.getItem('inquiriesData')) || [];
        }

        function triggerSystemNotification(msg) {
            const toast = document.getElementById('action-toast');
            document.getElementById('toast-text').textContent = msg;
            toast.classList.replace('hidden', 'flex');
            setTimeout(() => toast.classList.replace('flex','hidden'), 4000);
        }

        function initDashboardEngine() {
            loadDatasetsFromStorage();
            setupNavigation();
            calculateOverviewStats();
            hydrateSettingsForm();
            renderSliderAdminTable();
            renderCoursesAdminTable();
            renderVideosAdminTable();
            renderNotesAdminTable();
            renderGalleryAdminGrid();
            renderTestimonialsAdminContainer();
            renderInquiriesAdminTable();
            lucide.createIcons();
        }

        function calculateOverviewStats() {
            document.getElementById('stat-courses').textContent = coursesData.filter(c => c.active).length;
            document.getElementById('stat-videos').textContent = videosData.length;
            document.getElementById('stat-notes').textContent = notesData.length;
            document.getElementById('stat-inquiries').textContent = inquiriesData.length;
            
            const countBadge = document.getElementById('badge-inquiries-count');
            if(inquiriesData.length > 0) {
                countBadge.textContent = inquiriesData.length;
                countBadge.classList.remove('hidden');
            } else {
                countBadge.classList.add('hidden');
            }
        }

        function hydrateSettingsForm() {
            document.getElementById('set-inst-name').value = siteSettings.instituteName || '';
            document.getElementById('set-teacher-name').value = siteSettings.teacherName || '';
            document.getElementById('set-phone').value = siteSettings.phone || '';
            document.getElementById('set-whatsapp').value = siteSettings.whatsapp || '';
            document.getElementById('set-email').value = siteSettings.email || '';
            document.getElementById('set-address').value = siteSettings.address || '';
            document.getElementById('set-logo').value = siteSettings.logo || '';
            if(siteSettings.socialLinks) {
                document.getElementById('set-soc-yt').value = siteSettings.socialLinks.youtube || '';
                document.getElementById('set-soc-ig').value = siteSettings.socialLinks.instagram || '';
                document.getElementById('set-soc-fb').value = siteSettings.socialLinks.facebook || '';
                document.getElementById('set-soc-tg').value = siteSettings.socialLinks.telegram || '';
            }
        }

        document.getElementById('settings-form').addEventListener('submit', (e) => {
            e.preventDefault();
            siteSettings.instituteName = document.getElementById('set-inst-name').value;
            siteSettings.teacherName = document.getElementById('set-teacher-name').value;
            siteSettings.phone = document.getElementById('set-phone').value;
            siteSettings.whatsapp = document.getElementById('set-whatsapp').value;
            siteSettings.email = document.getElementById('set-email').value;
            siteSettings.address = document.getElementById('set-address').value;
            siteSettings.logo = document.getElementById('set-logo').value;
            siteSettings.socialLinks = {
                youtube: document.getElementById('set-soc-yt').value,
                instagram: document.getElementById('set-soc-ig').value,
                facebook: document.getElementById('set-soc-fb').value,
                telegram: document.getElementById('set-soc-tg').value,
                whatsapp: document.getElementById('set-whatsapp').value
            };
            localStorage.setItem('siteSettings', JSON.stringify(siteSettings));
            triggerSystemNotification("Site configuration dataset written successfully to local persistence layer.");
        });

        // Slider Actions Array Management
        document.getElementById('add-slide-btn').addEventListener('click', () => {
            document.getElementById('slider-form').classList.remove('hidden');
            document.getElementById('slider-form').reset();
            document.getElementById('slider-edit-id').value = '';
